# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/coaching_feed

# Redis (Docker locally: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Feed pagination
FEED_DEFAULT_LIMIT=20
FEED_MAX_LIMIT=100

# Cache
CACHE_TTL_SECONDS=300

# Auth
ADMIN_JWT_SECRET=your-secret-here

# Server
PORT=4000
